{
  "buildCommand": "",
  "installCommand": "",
  "outputDirectory": ".",
  "cleanUrls": true,
  "trailingSlash": false,
  "functions": {
    "api/refresh-market-data.js": { "maxDuration": 60 }
  },
  "rewrites": [
    { "source": "/callback", "destination": "/callback.html" },
    { "source": "/((?!api/|callback).*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/check-price-alerts",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/refresh-market-data",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/auto-post",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/sync-engagement",
      "schedule": "0 21 * * *"
    }
  ]
}
