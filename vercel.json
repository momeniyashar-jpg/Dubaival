{
  "version": 2,
  "framework": null,
  "buildCommand": "",
  "outputDirectory": ".",
  "rewrites": [
    {
      "source": "/((?!api/|js/|logo\\.png|manifest\\.json|sw\\.js).*)",
      "destination": "/index-6.html"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET,POST,OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type" }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/check-price-alerts",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/refresh-market-data",
      "schedule": "0 6 * * *"
    }
  ]
}
